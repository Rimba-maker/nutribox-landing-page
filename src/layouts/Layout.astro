---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "NutriBox — Catering Diet & Meal Prep Sehat | Delivery Harian Padang",
  description = "Meal prep sehat dikirim harian. Program weight loss, high protein, diabetic friendly, healthy heart, post-partum. Dirancang ahli gizi, bebas pengawet. Trial 5 hari mulai Rp 425k.",
} = Astro.props;
---

<!doctype html>
<html lang="id">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <slot />
  </body>
</html>
